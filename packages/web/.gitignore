# Sortida del compilador de Paraglide (regenerada per `npm run paraglide`).
# És un artefacte de build; no es versiona. La font de la i18n són
# project.inlang/settings.json + messages/*.json (sí versionats).
/src/lib/paraglide/

# Dada copiada per `prebuild` (scripts/copy-data.mjs) des de data/web/ (font: Sondeig).
# És un artefacte de build, NO la font: no es versiona aquí. Regenerable amb `npm run copy-data`.
/static/data/

# SvelteKit / Vite (també coberts pel .gitignore arrel del repo)
.svelte-kit/
build/
.vite/

# Dependències
node_modules/

# Logs locals
*.log
