{
  "name": "@datapoble/web",
  "private": true,
  "version": "0.0.1",
  "description": "datapoble — observatori territorial. Frontend (Mirador): SvelteKit + i18n ca/es.",
  "type": "module",
  "scripts": {
    "machine-translate": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
    "prepare": "npm run paraglide && svelte-kit sync || echo 'prepare skipped'",
    "dev": "npm run paraglide && vite dev",
    "build": "npm run paraglide && vite build",
    "preview": "vite preview",
    "check": "npm run paraglide && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.18.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@types/geojson": "^7946.0.14",
    "@types/node": "^22.0.0",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "svelte": "^5.56.1",
    "svelte-check": "^4.5.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "maplibre-gl": "^5.6.0"
  }
}
